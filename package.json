{
  "name": "eesa-portal",
  "version": "2.0.0",
  "description": "Egerton Engineering Student Association Portal",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "build": "npm run client:build",
    "dev": "concurrently \"node backend/server.js\" \"vite --config frontend/vite.config.js\"",
    "client:dev": "vite --config frontend/vite.config.js",
    "client:build": "vite build --config frontend/vite.config.js",
    "seed": "node backend/seed.js"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.1",
    "express-validator": "^7.3.2",
    "mongoose": "^8.8.0",
    "multer": "^2.0.0",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
